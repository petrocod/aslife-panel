# کپی روی سرور VPS:
#   cp env.docker.example .env
# docker-compose.yml از فایل .env استفاده می‌کند (--env-file .env)

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon...
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...

NEXT_PUBLIC_BASE_URL=https://asistan.example.com
ASISTAN_DOMAIN=asistan.example.com
NEXT_PUBLIC_SALES_EMAIL=satis@aslife.com.tr
CRON_SECRET=random-long-secret

VERIMOR_USERNAME=
VERIMOR_PASSWORD=
VERIMOR_SOURCE_ADDR=
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# production — خاموش بماند
# DEMO_SEED_OPEN_IN_DEV=
# NEXT_PUBLIC_SUPABASE_DEV_BYPASS=

# Geçici test: SMS atlanır, OTP ekranda gösterilir (canlıda sonra kapatın)
# OTP_DEV_FALLBACK=true

# Yeni kayıt (Kayıt Ol) — invite-only için false bırakın
PUBLIC_SIGNUP_ENABLED=false

# Destek talepleri — e-posta bildirimleri
SUPPORT_ADMIN_EMAIL=support@asistan.example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@asistan.example.com
